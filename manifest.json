{
  "manifest_version": 3,
  "name": "Swap Path Finder",
  "version": "1.2",
  "description": "Home exchange multiswap route finder for GlassBob and HomeSwapper",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}